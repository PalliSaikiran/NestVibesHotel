<%- include('partials/header', { title: 'Login' }) %>

<section class="form-page">
  <div class="form-card">
    <h1 class="form-title">🔐 Login</h1>
    <p class="form-subtitle">Welcome back! Please login to your account.</p>

    <form action="/login" method="POST" novalidate>
      <div class="form-group full-width">
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" class="input" placeholder="your@email.com" required />
      </div>

      <div class="form-group full-width">
        <label for="password">Password *</label>
        <input type="password" id="password" name="password" class="input" placeholder="••••••••" required />
      </div>

      <div class="form-actions">
        <a href="/listings" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">Login</button>
      </div>
    </form>

    <p class="form-footer">
      Don't have an account? <a href="/register" class="link">Register here</a>
    </p>
  </div>
</section>

<%- include('partials/footer') %>

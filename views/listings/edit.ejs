<%- include('../partials/header', { title: 'Edit Listing' }) %>

<section class="form-page">
  <div class="form-card">
    <h1 class="form-title">✏ Edit Listing</h1>
    <p class="form-subtitle">Update the details for <strong><%= listing.title %></strong>.</p>

    <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" novalidate>

      <div class="form-grid">
        <div class="form-group full-width">
          <label for="title">Property Title *</label>
          <input type="text" id="title" name="listing[title]" class="input" value="<%= listing.title %>" required />
        </div>

        <div class="form-group full-width">
          <label for="description">Description *</label>
          <textarea id="description" name="listing[description]" class="input textarea" rows="4" required><%= listing.description %></textarea>
        </div>

        <div class="form-group">
          <label for="price">Price per Night (₹) *</label>
          <input type="number" id="price" name="listing[price]" class="input" min="0" value="<%= listing.price %>" required />
        </div>

        <div class="form-group">
          <label for="category">Category *</label>
          <select id="category" name="listing[category]" class="input select-input" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat %>" <%= listing.category === cat ? 'selected' : '' %>><%= cat %></option>
            <% }) %>
          </select>
        </div>

        <div class="form-group">
          <label for="location">City / Town *</label>
          <input type="text" id="location" name="listing[location]" class="input" value="<%= listing.location %>" required />
        </div>

        <div class="form-group">
          <label for="country">Country *</label>
          <input type="text" id="country" name="listing[country]" class="input" value="<%= listing.country %>" required />
        </div>

        <div class="form-group full-width">
          <label for="image">Image URL <span class="optional">(optional)</span></label>
          <input type="url" id="image" name="listing[image]" class="input" value="<%= listing.image %>" />
        </div>
      </div>

      <div class="form-actions">
        <a href="/listings/<%= listing._id %>" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
</section>

<%- include('../partials/footer') %>

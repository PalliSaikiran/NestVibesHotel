<%- include('../partials/header', { title: listing.title }) %>

<section class="show-page">

  <!-- ─── Hero Image ─────────────────────────────────────────── -->
  <div class="show-hero">
    <img
      src="<%= listing.image %>"
      alt="<%= listing.title %>"
      class="show-hero-image"
      onerror="this.src='https://images.pexels.com/photos/280229/pexels-photo-280229.jpeg?auto=compress&cs=tinysrgb&w=800'"
    />
    <span class="show-category"><%= listing.category %></span>
  </div>

  <div class="show-layout">

    <!-- ─── Listing Details ──────────────────────────────────── -->
    <div class="show-main">
      <div class="show-header">
        <div>
          <h1 class="show-title"><%= listing.title %></h1>
          <p class="show-location">📍 <%= listing.location %>, <%= listing.country %></p>
        </div>
        <div class="show-price-block">
          <span class="show-price">₹<%= listing.price.toLocaleString('en-IN') %></span>
          <span class="show-price-label">/ night</span>
        </div>
      </div>

      <% if (avgRating) { %>
        <div class="avg-rating">
          ⭐ <strong><%= avgRating %></strong> / 5
          <span class="review-count">(<%= listing.reviews.length %> review<%= listing.reviews.length !== 1 ? 's' : '' %>)</span>
        </div>
      <% } %>

      <div class="show-description">
        <h2>About this property</h2>
        <p><%= listing.description %></p>
      </div>

      <% if (isOwner) { %>
        <div class="show-actions">
          <a href="/listings/<%= listing._id %>/edit" class="btn btn-secondary">✏ Edit</a>
          <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this listing?')">
            <button type="submit" class="btn btn-danger">🗑 Delete</button>
          </form>
        </div>
      <% } %>
    </div>

    <!-- ─── Reviews Sidebar ──────────────────────────────────── -->
    <aside class="show-sidebar">

      <!-- Add Review Form -->
      <div class="review-form-card">
        <h2>Leave a Review</h2>
        <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate>

          <div class="form-group">
            <label>Rating</label>
            <div class="star-rating" id="starRating">
              <% for (let i = 1; i <= 5; i++) { %>
                <input type="radio" id="star<%= i %>" name="review[rating]" value="<%= i %>" required />
                <label for="star<%= i %>" class="star" title="<%= i %> star">★</label>
              <% } %>
            </div>
          </div>

          <div class="form-group">
            <label for="reviewBody">Your Review</label>
            <textarea id="reviewBody" name="review[body]" class="input textarea" rows="3" placeholder="Share your experience…" required minlength="5"></textarea>
          </div>

          <button type="submit" class="btn btn-primary full-width">Post Review</button>
        </form>
      </div>

      <!-- Review List -->
      <% if (listing.reviews.length > 0) { %>
        <div class="review-list">
          <h3><%= listing.reviews.length %> Review<%= listing.reviews.length !== 1 ? 's' : '' %></h3>
          <% listing.reviews.forEach(review => { %>
            <div class="review-card">
              <div class="review-header">
                <div class="review-stars">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <span class="<%= i <= review.rating ? 'star filled' : 'star' %>">★</span>
                  <% } %>
                </div>
                <span class="review-date"><%= new Date(review.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %></span>
              </div>
              <p class="review-body"><%= review.body %></p>
              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn-link btn-danger-link">Delete review</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% } %>

    </aside>
  </div>
</section>

<a href="/listings" class="back-link">← Back to Listings</a>

<%- include('../partials/footer') %>

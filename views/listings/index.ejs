<%- include('../partials/header', { title: 'Browse Listings' }) %>

<section class="page-hero">
  <h1>Find Your Perfect Stay</h1>
  <p>Explore handpicked properties around the world</p>
</section>

<!-- ─── Search & Filter Bar ───────────────────────────────────────── -->
<section class="filter-bar">
  <form action="/listings" method="GET" class="filter-form">
    <div class="search-wrap">
      <input
        type="text"
        name="search"
        placeholder="Search by city, country or title…"
        value="<%= currentSearch %>"
        class="input search-input"
      />
      <button type="submit" class="btn btn-primary">Search</button>
    </div>

    <div class="filter-controls">
      <select name="category" class="input select-input" onchange="this.form.submit()">
        <option value="">All Categories</option>
        <% categories.forEach(cat => { %>
          <option value="<%= cat %>" <%= currentCategory === cat ? 'selected' : '' %>><%= cat %></option>
        <% }) %>
      </select>

      <select name="sort" class="input select-input" onchange="this.form.submit()">
        <option value="">Sort By</option>
        <option value="price_asc"  <%= currentSort === 'price_asc'  ? 'selected' : '' %>>Price: Low → High</option>
        <option value="price_desc" <%= currentSort === 'price_desc' ? 'selected' : '' %>>Price: High → Low</option>
        <option value="newest"     <%= currentSort === 'newest'     ? 'selected' : '' %>>Newest First</option>
      </select>

      <% if (currentCategory || currentSearch || currentSort) { %>
        <a href="/listings" class="btn btn-ghost">Clear</a>
      <% } %>
    </div>
  </form>
</section>

<!-- ─── Listings Grid ──────────────────────────────────────────────── -->
<section class="listings-section">
  <% if (listings.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">🏚</div>
      <h2>No listings found</h2>
      <p>Try a different search or <a href="/listings/new">add the first one</a>.</p>
    </div>
  <% } else { %>
    <p class="result-count"><%= listings.length %> propert<%= listings.length === 1 ? 'y' : 'ies' %> found</p>
    <div class="listings-grid">
      <% listings.forEach(listing => { %>
        <article class="listing-card">
          <a href="/listings/<%= listing._id %>" class="card-image-link">
            <img
              src="<%= listing.image %>"
              alt="<%= listing.title %>"
              class="card-image"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
            <div class="card-image-placeholder" style="display: none; width: 100%; height: 200px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); align-items: center; justify-content: center; color: white; font-size: 2rem;">
              🏠
            </div>
            <span class="card-category"><%= listing.category %></span>
          </a>
          <div class="card-body">
            <h3 class="card-title"><a href="/listings/<%= listing._id %>"><%= listing.title %></a></h3>
            <p class="card-location">📍 <%= listing.location %>, <%= listing.country %></p>
            <p class="card-price"><strong>₹<%= listing.price.toLocaleString('en-IN') %></strong> / night</p>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('../partials/footer') %>
